class Solution {
public:
    int evalRPN(vector<string>& tokens) {
        stack<int> st;
        
        for (const string& token : tokens) {
            // Check if the token is an operator
            if (token == "+" || token == "-" || token == "*" || token == "/") {
                // The first element popped is the right operand
                int b = st.top(); st.pop();
                // The second element popped is the left operand
                int a = st.top(); st.pop();
                
                // Perform the operation and push the result back
                if (token == "+") st.push(a + b);
                else if (token == "-") st.push(a - b);
                else if (token == "*") st.push(a * b);
                else if (token == "/") st.push(a / b); // C++ division naturally truncates toward zero
            } else {
                // It's a number, convert string to integer and push
                st.push(stoi(token));
            }
        }
        
        // The final remaining element is the result
        return st.top();
    }
};
